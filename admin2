   INIT
═══════════════════════════════════════════ */
async function initApp(){
  startClock();
  populateDeptDropdowns();
  await refreshData();
  renderCharts();
}

async function refreshData(){
  try {
    const [statsRes, usersRes, tasksRes] = await Promise.all([
      gasPost({action:'getDashboardStats'}),
      gasPost({action:'getAllUsers'}),
      gasPost({action:'getAllTasks'})
    ]);

    if(statsRes.success && statsRes.stats){
      const s = statsRes.stats;
      document.getElementById('statUsers').textContent = s.totalUsers || '—';
      document.getElementById('statTasks').textContent = s.totalTasks || '—';
      document.getElementById('statHours').textContent = s.totalMins ? (s.totalMins/60).toFixed(1)+'h' : '—';
      document.getElementById('statActivity').textContent = s.totalActivities || '—';
    } else {
      // Fallback to local data
      const lu = JSON.parse(localStorage.getItem('gh_users')||'[]');
      const lt = JSON.parse(localStorage.getItem('gh_tasks')||'[]');
      const la = JSON.parse(localStorage.getItem('gh_activity')||'[]');
      document.getElementById('statUsers').textContent = lu.length;
      document.getElementById('statTasks').textContent = lt.length;
      const mins = lt.reduce((s,t)=>s+Number(t.durationMinutes||0),0);
      document.getElementById('statHours').textContent = (mins/60).toFixed(1)+'h';
      document.getElementById('statActivity').textContent = la.length;
      allUsers = lu; allTasks = lt; allActivity = la;
    }

    if(usersRes.success && usersRes.users) {
      allUsers = usersRes.users;
      document.getElementById('statUsers').textContent = allUsers.length;
    } else {
      allUsers = JSON.parse(localStorage.getItem('gh_users')||'[]').map(u=>{const c={...u};delete c.password;return c;});
    }

    if(tasksRes.success && tasksRes.tasks) {
      allTasks = tasksRes.tasks;
    } else {
      allTasks = JSON.parse(localStorage.getItem('gh_tasks')||'[]');
    }

    renderDashboardWidgets();
    toast('Data refreshed','success');
  } catch(e) {
    // All local fallback
    allUsers = JSON.parse(localStorage.getItem('gh_users')||'[]').map(u=>{const c={...u};delete c.password;return c;});
    allTasks = JSON.parse(localStorage.getItem('gh_tasks')||'[]');
    allActivity = JSON.parse(localStorage.getItem('gh_activity')||'[]');
    document.getElementById('statUsers').textContent = allUsers.length;
    document.getElementById('statTasks').textContent = allTasks.length;
    const mins = allTasks.reduce((s,t)=>s+Number(t.durationMinutes||0),0);
    document.getElementById('statHours').textContent = (mins/60).toFixed(1)+'h';
    document.getElementById('statActivity').textContent = allActivity.length;
    renderDashboardWidgets();
    toast('Working offline (local data)','info');
  }
}

/* ═══════════════════════════════════════════
   DASHBOARD WIDGETS
═══════════════════════════════════════════ */
function renderDashboardWidgets(){
  // Recent timeline from localStorage
  const acts = JSON.parse(localStorage.getItem('gh_activity')||'[]').slice(-8).reverse();
  const tl = document.getElementById('recentTimeline');
  if(acts.length===0){tl.innerHTML='<div style="text-align:center;padding:20px;color:var(--tx3);font-size:13px;">No activity yet</div>';return;}
  tl.innerHTML = acts.map((a,i)=>`
    <div class="tl-item">
      <div class="tl-dot-wrap">
        <div class="tl-dot" style="background:${actionColor(a.action)}"></div>
        ${i<acts.length-1?'<div class="tl-line"></div>':''}
      </div>
      <div class="tl-body">
        <div class="tl-action">${a.action||'EVENT'}</div>
        <div class="tl-detail">${a.details||''}</div>
        <div class="tl-meta">${a.empId||''} • ${fmtTs(a.timestamp)}</div>
      </div>
    </div>
  `).join('');

  // Top employees
  const empHours = {};
  allTasks.forEach(t=>{
    const id = t.empId||t.userId||'?';
    empHours[id] = (empHours[id]||0) + Number(t.durationMinutes||0);
  });
  const sorted = Object.entries(empHours).sort((a,b)=>b[1]-a[1]).slice(0,6);
  const maxMins = sorted[0]?.[1]||1;
  document.getElementById('topEmployees').innerHTML = sorted.length===0
    ? '<div style="text-align:center;color:var(--tx3);">No task data yet</div>'
    : sorted.map(([id,mins])=>`
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <span style="font-size:13px;font-weight:700;color:var(--tx);">${id}</span>
          <span style="font-size:12px;color:var(--p);font-weight:700;">${(mins/60).toFixed(1)}h</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" style="width:${Math.round(mins/maxMins*100)}%"></div></div>
      </div>
    `).join('');

  // Dashboard announcements
  loadDashAnnouncements();
}

function actionColor(a){
  if(!a) return 'var(--p)';
  if(/LOGIN|REGISTER/.test(a)) return 'var(--ok)';
  if(/LOGOUT/.test(a)) return 'var(--danger)';
  if(/TIMER/.test(a)) return 'var(--warn)';
  return 'var(--p)';
}

async function loadDashAnnouncements(){
  const el = document.getElementById('dashAnnouncements');
  try {
    const res = await gasPost({action:'getAnnouncements'});
    if(res.success) allAnn = res.announcements||[];
  } catch(e){}
  if(allAnn.length===0){el.innerHTML='<div style="text-align:center;color:var(--tx3);">No announcements posted yet</div>';return;}
  el.innerHTML = allAnn.slice(0,3).map(a=>`
    <div class="announcement-card">
      <div class="ann-title">${esc(a.title)}</div>
      <div class="ann-msg">${esc(a.message)}</div>
      <div class="ann-meta">Target: ${a.targetDept||'ALL'} • ${fmtTs(a.createdAt)} by ${esc(a.createdBy||'Admin')}</div>
    </div>
  `).join('');
}

