<!DOCTYPE html>
<html lang="en" data-theme="dark" data-animations="true">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>Gigahertz — Admin Console</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Exo+2:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300&display=swap" rel="stylesheet"/>

<style>
/* ═══════════════════════════════════════════
   THEME SYSTEM & CSS VARIABLES
═══════════════════════════════════════════ */
:root {
  --glass: rgba(255,255,255,0.06);
  --glass-border: rgba(255,255,255,0.14);
  --glass-hover: rgba(255,255,255,0.12);
  --glass-active: rgba(255,255,255,0.18);
  --blur: blur(18px) saturate(180%);
  --blur-sm: blur(10px) saturate(140%);
  --r: 16px;
  --r-sm: 10px;
  --r-lg: 24px;
  --tx: #e8f0fe;
  --tx2: #8fa8d4;
  --tx3: #5a74a0;
  --danger: #ff4d6d;
  --ok: #39ff97;
  --warn: #ffd166;
  --font: 'Exo 2', system-ui, sans-serif;
  --font-display: 'Rajdhani', system-ui, sans-serif;
}

/* ── DARK (default) ── */
[data-theme="dark"] {
  --bg1: #030711;
  --bg2: #050d1a;
  --bg3: #071426;
  --p: #4d8af0;
  --pd: #2563eb;
  --pl: rgba(77,138,240,0.15);
  --accent: #00d4ff;
  --sh: 0 8px 32px rgba(0,0,0,0.6);
  --glow: 0 0 40px rgba(77,138,240,0.3);
}
/* ── LIGHT ── */
[data-theme="light"] {
  --bg1: #dde8f8;
  --bg2: #e8f0fc;
  --bg3: #f0f5ff;
  --p: #1a56db;
  --pd: #1043b5;
  --pl: rgba(26,86,219,0.1);
  --accent: #006aff;
  --tx: #0d1733;
  --tx2: #3a5080;
  --tx3: #7a90bc;
  --sh: 0 8px 32px rgba(30,60,120,0.12);
  --glow: 0 0 30px rgba(26,86,219,0.15);
  --glass: rgba(255,255,255,0.55);
  --glass-border: rgba(255,255,255,0.8);
  --glass-hover: rgba(255,255,255,0.7);
}
/* ── MIDNIGHT PURPLE ── */
[data-theme="purple"] {
  --bg1: #080510;
  --bg2: #100b1e;
  --bg3: #160f2c;
  --p: #a855f7;
  --pd: #9333ea;
  --pl: rgba(168,85,247,0.15);
  --accent: #e879f9;
  --sh: 0 8px 32px rgba(0,0,0,0.6);
  --glow: 0 0 40px rgba(168,85,247,0.3);
}
/* ── EMERALD ── */
[data-theme="emerald"] {
  --bg1: #020e0a;
  --bg2: #04180f;
  --bg3: #062218;
  --p: #10b981;
  --pd: #059669;
  --pl: rgba(16,185,129,0.15);
  --accent: #34d399;
  --sh: 0 8px 32px rgba(0,0,0,0.6);
  --glow: 0 0 40px rgba(16,185,129,0.3);
}
/* ── ROSE ── */
[data-theme="rose"] {
  --bg1: #0e0407;
  --bg2: #180810;
  --bg3: #22081a;
  --p: #f43f5e;
  --pd: #e11d48;
  --pl: rgba(244,63,94,0.15);
  --accent: #fb7185;
  --sh: 0 8px 32px rgba(0,0,0,0.6);
  --glow: 0 0 40px rgba(244,63,94,0.3);
}

/* ═══════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:var(--font);background:var(--bg1);color:var(--tx);overflow:hidden;}
input,select,button,textarea{font-family:inherit;}
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--glass-border);border-radius:99px;}
::-webkit-scrollbar-thumb:hover{background:var(--p);}
::selection{background:var(--pl);color:var(--p);}

/* ═══════════════════════════════════════════
   ANIMATED BACKGROUND
═══════════════════════════════════════════ */
.bg-scene{position:fixed;inset:0;z-index:0;overflow:hidden;}
.bg-scene::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 30%, rgba(77,138,240,0.12) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 80% 70%, rgba(0,212,255,0.07) 0%, transparent 55%),
    radial-gradient(ellipse 50% 40% at 50% 50%, rgba(77,138,240,0.04) 0%, transparent 60%);
  animation: bg-breathe 12s ease-in-out infinite alternate;
}
.bg-scene::after{
  content:'';position:absolute;inset:0;
  background: linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 50%, var(--bg3) 100%);
}
@keyframes bg-breathe{
  0%{transform:scale(1) translateX(0);}
  100%{transform:scale(1.05) translateX(-2%);}
}

/* Floating orbs */
.orb{position:absolute;border-radius:50%;filter:blur(60px);pointer-events:none;opacity:0.4;}
.orb-1{width:500px;height:500px;background:radial-gradient(circle,var(--p) 0%,transparent 70%);top:-150px;left:-100px;animation:float1 20s ease-in-out infinite;}
.orb-2{width:400px;height:400px;background:radial-gradient(circle,var(--accent) 0%,transparent 70%);bottom:-100px;right:-80px;animation:float2 25s ease-in-out infinite;}
.orb-3{width:300px;height:300px;background:radial-gradient(circle,var(--p) 0%,transparent 70%);top:40%;left:40%;animation:float3 18s ease-in-out infinite;}
@keyframes float1{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(80px,60px) scale(1.1);}}
@keyframes float2{0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-60px,-80px) scale(1.15);}}
@keyframes float3{0%,100%{transform:translate(0,0) scale(0.8);}50%{transform:translate(40px,-40px) scale(1.1);}}
[data-animations="false"] .orb,.bg-scene::before{animation:none!important;}

/* ═══════════════════════════════════════════
   GLASS MIXIN UTILITY
═══════════════════════════════════════════ */
.glass{
  background:var(--glass);
  -webkit-backdrop-filter:var(--blur);
  backdrop-filter:var(--blur);
  border:1px solid var(--glass-border);
  border-radius:var(--r);
}
.glass-sm{
  background:var(--glass);
  -webkit-backdrop-filter:var(--blur-sm);
  backdrop-filter:var(--blur-sm);
  border:1px solid var(--glass-border);
  border-radius:var(--r-sm);
}

/* ═══════════════════════════════════════════
   LOGIN SCREEN
═══════════════════════════════════════════ */
#login-screen{
  position:fixed;inset:0;z-index:1000;
  display:flex;align-items:center;justify-content:center;
  padding:20px;
}
.login-card{
  background:rgba(5,15,35,0.75);
  -webkit-backdrop-filter:blur(32px) saturate(200%);
  backdrop-filter:blur(32px) saturate(200%);
  border:1px solid rgba(255,255,255,0.15);
  border-radius:24px;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.05),
    0 32px 80px rgba(0,0,0,0.6),
    inset 0 1px 0 rgba(255,255,255,0.1);
  padding:44px 40px;
  width:100%;max-width:460px;
  position:relative;overflow:hidden;
}
[data-theme="light"] .login-card{
  background:rgba(225,235,255,0.75);
  border-color:rgba(255,255,255,0.9);
  box-shadow:0 32px 80px rgba(30,60,120,0.2);
}
.login-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);
}
.login-logo{display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:28px;}
.login-logo img{height:52px;object-fit:contain;mix-blend-mode:multiply;}
[data-theme="dark"] .login-logo img,[data-theme="purple"] .login-logo img,[data-theme="emerald"] .login-logo img,[data-theme="rose"] .login-logo img{
  filter:invert(1) brightness(2);mix-blend-mode:screen;
}
.login-brand{font-family:var(--font-display);font-size:11px;font-weight:700;letter-spacing:.2em;color:var(--p);text-transform:uppercase;}
.login-title{font-family:var(--font-display);font-size:26px;font-weight:700;color:var(--tx);text-align:center;margin-bottom:4px;}
.login-sub{font-size:13px;color:var(--tx2);text-align:center;margin-bottom:28px;}
.login-gear{
  position:absolute;bottom:16px;left:16px;
  width:36px;height:36px;
  background:var(--glass);
  border:1px solid var(--glass-border);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--tx2);
  transition:.2s;z-index:10;
}
.login-gear:hover{background:var(--glass-hover);color:var(--tx);transform:rotate(30deg);}
[data-animations="false"] .login-gear:hover{transform:none;}

/* THEME DROPDOWN */
.theme-dropdown{
  position:absolute;bottom:58px;left:16px;
  background:rgba(5,15,35,0.92);
  -webkit-backdrop-filter:blur(24px);
  backdrop-filter:blur(24px);
  border:1px solid var(--glass-border);
  border-radius:14px;
  padding:12px;
  display:none;flex-direction:column;gap:6px;
  min-width:200px;z-index:20;
  box-shadow:0 20px 60px rgba(0,0,0,0.5);
  animation:dropdown-in .2s ease;
}
[data-theme="light"] .theme-dropdown{background:rgba(220,235,255,0.95);}
.theme-dropdown.open{display:flex;}
@keyframes dropdown-in{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.td-label{font-size:10px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.1em;padding:2px 4px;margin-bottom:2px;}
.td-row{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:.15s;}
.td-row:hover{background:var(--glass-hover);}
.td-row.active{background:var(--pl);}
.td-swatch{width:18px;height:18px;border-radius:50%;flex-shrink:0;border:2px solid transparent;}
.td-row.active .td-swatch{border-color:var(--tx);}
.td-name{font-size:13px;font-weight:600;color:var(--tx2);}
.td-row.active .td-name{color:var(--p);}

/* FORM ELEMENTS */
.fg{margin-bottom:14px;position:relative;}
.fg label{font-size:10.5px;font-weight:700;color:var(--tx2);display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:.06em;}
.fi{
  width:100%;padding:11px 14px;
  background:rgba(255,255,255,0.06);
  border:1px solid var(--glass-border);
  border-radius:10px;
  font-size:13.5px;color:var(--tx);outline:none;
  transition:.2s;
}
[data-theme="light"] .fi{background:rgba(255,255,255,0.6);}
.fi:focus{border-color:var(--p);background:rgba(255,255,255,0.1);box-shadow:0 0 0 3px var(--pl);}
.fi::placeholder{color:var(--tx3);}
.pw-wrap{position:relative;display:flex;}
.pw-wrap .fi{padding-right:42px;}
.pw-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--tx3);padding:4px;border-radius:4px;}
.pw-eye:hover{color:var(--tx);}
.btn-primary{
  display:flex;align-items:center;justify-content:center;gap:8px;
  width:100%;padding:12px;
  background:linear-gradient(135deg, var(--p), var(--pd));
  color:#fff;border:none;border-radius:10px;
  font-size:14px;font-weight:700;cursor:pointer;
  transition:all .2s;
  box-shadow:0 4px 20px var(--pl), inset 0 1px 0 rgba(255,255,255,0.2);
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px var(--pl), inset 0 1px 0 rgba(255,255,255,0.2);}
.btn-primary:active{transform:translateY(0);}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none;}
[data-animations="false"] .btn-primary:hover{transform:none;}
.err-box{background:rgba(255,77,109,0.15);border:1px solid rgba(255,77,109,0.3);color:var(--danger);padding:10px 13px;border-radius:8px;font-size:13px;margin-bottom:12px;}

/* ═══════════════════════════════════════════
   MAIN LAYOUT
═══════════════════════════════════════════ */
#app{position:fixed;inset:0;z-index:1;display:flex;overflow:hidden;}
#app.hidden{display:none;}

/* SIDEBAR */
.sidebar{
  width:260px;height:100%;flex-shrink:0;
  display:flex;flex-direction:column;
  background:rgba(5,12,28,0.7);
  -webkit-backdrop-filter:var(--blur);
  backdrop-filter:var(--blur);
  border-right:1px solid var(--glass-border);
  position:relative;z-index:10;
  transition:transform .3s cubic-bezier(.4,0,.2,1), width .3s;
  overflow:hidden;
}
[data-theme="light"] .sidebar{background:rgba(210,225,255,0.7);}

/* Sidebar top chrome line */
.sidebar::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);
}

.sb-logo{padding:22px 20px 12px;display:flex;align-items:center;gap:10px;}
.sb-logo img{height:36px;object-fit:contain;mix-blend-mode:multiply;}
[data-theme="dark"] .sb-logo img,[data-theme="purple"] .sb-logo img,[data-theme="emerald"] .sb-logo img,[data-theme="rose"] .sb-logo img{
  filter:invert(1) brightness(2);mix-blend-mode:screen;
}
.sb-logo-text{font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--tx);}
.sb-logo-sub{font-size:9px;font-weight:700;letter-spacing:.15em;color:var(--p);text-transform:uppercase;margin-top:-2px;}

.sb-nav{flex:1;padding:12px;overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column;gap:2px;}
.nav-section-label{font-size:9px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.12em;padding:10px 12px 4px;}
.nav-item{
  display:flex;align-items:center;gap:12px;
  padding:11px 14px;border-radius:12px;
  cursor:pointer;color:var(--tx2);
  font-size:13.5px;font-weight:600;
  transition:all .2s;
  position:relative;overflow:hidden;
  border:1px solid transparent;
  white-space:nowrap;
}
.nav-item::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,var(--p),transparent);
  opacity:0;transition:opacity .2s;border-radius:12px;
}
.nav-item:hover{color:var(--tx);background:var(--glass-hover);}
.nav-item.active{
  color:var(--p);
  background:var(--pl);
  border-color:rgba(77,138,240,0.2);
  font-weight:700;
}
.nav-item.active::before{opacity:0.05;}
.nav-item svg{width:18px;height:18px;flex-shrink:0;z-index:1;}
.nav-item span{z-index:1;flex:1;}
.nav-badge{
  background:var(--danger);color:#fff;
  font-size:10px;font-weight:800;
  padding:2px 7px;border-radius:99px;
  z-index:1;
}

.sb-bottom{padding:12px;display:flex;flex-direction:column;gap:8px;}

/* ADMIN USER CARD */
.sb-user{
  background:var(--pl);
  border:1px solid rgba(77,138,240,0.2);
  border-radius:14px;
  padding:12px 14px;
  display:flex;align-items:center;gap:10px;
}
.sb-avatar{
  width:36px;height:36px;border-radius:50%;
  background:linear-gradient(135deg,var(--p),var(--accent));
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-weight:800;font-size:15px;flex-shrink:0;
  box-shadow:0 4px 12px var(--pl);
}
.sb-user-name{font-size:13px;font-weight:700;color:var(--tx);}
.sb-user-role{font-size:10.5px;color:var(--tx3);font-weight:600;}

.logout-btn{
  display:flex;align-items:center;justify-content:center;gap:8px;
  padding:10px;border-radius:12px;
  background:linear-gradient(135deg,var(--p),var(--pd));
  color:#fff;border:none;cursor:pointer;
  font-size:13.5px;font-weight:700;
  transition:all .2s;
  box-shadow:0 4px 16px var(--pl);
}
.logout-btn:hover{transform:translateY(-1px);filter:brightness(1.1);}
[data-animations="false"] .logout-btn:hover{transform:none;}

/* MAIN CONTENT */
.main-content{flex:1;height:100%;display:flex;flex-direction:column;overflow:hidden;}

/* TOP BAR */
.topbar{
  height:62px;flex-shrink:0;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
  background:rgba(5,12,28,0.5);
  -webkit-backdrop-filter:var(--blur-sm);
  backdrop-filter:var(--blur-sm);
  border-bottom:1px solid var(--glass-border);
}
[data-theme="light"] .topbar{background:rgba(210,225,255,0.5);}
.topbar-left{display:flex;align-items:center;gap:14px;}
.mobile-toggle{
  display:none;background:var(--glass);border:1px solid var(--glass-border);
  border-radius:8px;padding:7px 10px;cursor:pointer;color:var(--tx);font-size:18px;
}
.topbar-title{font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--tx);}
.topbar-sub{font-size:12px;color:var(--tx2);margin-top:1px;}
.topbar-right{display:flex;align-items:center;gap:10px;}

/* Search bar */
.search-bar{
  display:flex;align-items:center;gap:8px;
  background:var(--glass);border:1px solid var(--glass-border);
  border-radius:10px;padding:8px 14px;min-width:220px;
}
.search-bar input{background:none;border:none;outline:none;font-size:13px;color:var(--tx);width:100%;}
.search-bar input::placeholder{color:var(--tx3);}
.search-bar svg{color:var(--tx3);flex-shrink:0;}

.topbar-time{
  font-family:var(--font-display);font-size:15px;font-weight:600;
  color:var(--p);background:var(--pl);
  padding:6px 14px;border-radius:8px;
  letter-spacing:.04em;
}
.icon-btn{
  width:38px;height:38px;background:var(--glass);border:1px solid var(--glass-border);
  border-radius:10px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--tx2);transition:.2s;position:relative;
}
.icon-btn:hover{background:var(--glass-hover);color:var(--tx);}
.icon-btn .badge{
  position:absolute;top:-4px;right:-4px;
  background:var(--danger);color:#fff;
  font-size:9px;font-weight:800;
  width:16px;height:16px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}

/* PAGE CONTENT */
.page-content{flex:1;overflow-y:auto;overflow-x:hidden;padding:24px 28px;}

/* ═══════════════════════════════════════════
   STAT CARDS
═══════════════════════════════════════════ */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.stat-card{
  background:var(--glass);
  -webkit-backdrop-filter:var(--blur);
  backdrop-filter:var(--blur);
  border:1px solid var(--glass-border);
  border-radius:var(--r);
  padding:20px 22px;
  position:relative;overflow:hidden;
  transition:all .3s cubic-bezier(.4,0,.2,1);
  cursor:default;
}
.stat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--p),transparent);
  opacity:0;transition:opacity .3s;
}
.stat-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,0.4),var(--glow);}
.stat-card:hover::before{opacity:1;}
[data-animations="false"] .stat-card:hover{transform:none;}
.stat-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;background:var(--pl);}
.stat-icon svg{color:var(--p);}
.stat-label{font-size:11px;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;}
.stat-value{font-family:var(--font-display);font-size:30px;font-weight:700;color:var(--tx);line-height:1;letter-spacing:-1px;}
.stat-sub{font-size:11px;color:var(--tx3);margin-top:6px;}

/* ═══════════════════════════════════════════
   CARDS / PANELS
═══════════════════════════════════════════ */
.panel{
  background:var(--glass);
  -webkit-backdrop-filter:var(--blur);
  backdrop-filter:var(--blur);
  border:1px solid var(--glass-border);
  border-radius:var(--r);
  overflow:hidden;
  margin-bottom:20px;
}
.panel-hdr{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 22px;
  border-bottom:1px solid var(--glass-border);
  flex-wrap:wrap;gap:10px;
}
.panel-title{font-family:var(--font-display);font-size:16px;font-weight:700;color:var(--tx);}
.panel-sub{font-size:12px;color:var(--tx3);margin-top:2px;}
.panel-body{padding:20px 22px;}

/* ═══════════════════════════════════════════
   TABLE
═══════════════════════════════════════════ */
.table-wrap{overflow-x:auto;}
.data-table{width:100%;border-collapse:collapse;min-width:600px;}
.data-table th{
  padding:12px 16px;text-align:left;
  font-size:10.5px;font-weight:700;color:var(--tx2);
  text-transform:uppercase;letter-spacing:.06em;
  border-bottom:1px solid var(--glass-border);
  position:sticky;top:0;background:rgba(5,12,28,0.8);
  -webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);
}
[data-theme="light"] .data-table th{background:rgba(210,225,255,0.8);}
.data-table td{
  padding:13px 16px;font-size:13px;color:var(--tx);
  border-bottom:1px solid rgba(255,255,255,0.05);
  transition:.15s;
}
.data-table tr:hover td{background:var(--glass-hover);}
.data-table tr:last-child td{border-bottom:none;}
.dept-badge{
  display:inline-block;padding:3px 10px;
  border-radius:99px;font-size:10.5px;font-weight:700;
  background:var(--pl);color:var(--p);
