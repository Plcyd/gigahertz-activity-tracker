  if(res.success) toast('✓ Connected! Sheets: '+res.sheetsCount,'success');
  else if(res._noCors) toast('Request sent (no-cors mode — check Sheet)','info');
  else toast(res.error||'Connection failed','error');
}
async function getDiagnostics(){
  const res = await gasPost({action:'getDiagnosticReport'});
  const body = document.getElementById('diagBody');
  if(res.success && res.sheetsStatus){
    const rows = Object.entries(res.sheetsStatus).map(([name,info])=>`
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--glass-border);font-size:13px;">
        <span style="font-weight:600;color:var(--tx);">${esc(name)}</span>
        <span class="status-badge ${info.status==='OK'?'ok':'danger'}"><span class="status-dot"></span>${info.status} ${info.rowCount!==undefined?'('+info.rowCount+' rows)':''}</span>
      </div>
    `).join('');
    body.innerHTML = `<div style="margin-bottom:12px;font-size:12px;color:var(--tx2);">Report generated ${fmtTs(res.timestamp)}</div>${rows}`;
  } else if(res._noCors){
    body.innerHTML = '<p style="color:var(--tx2);">Sent in no-cors mode — open Google Sheet to verify</p>';
  } else {
    body.innerHTML = `<p style="color:var(--danger);">${esc(res.error||'Failed')}</p>`;
  }
  openModal('diagModal');
}

/* ═══════════════════════════════════════════
   GLOBAL SEARCH
═══════════════════════════════════════════ */
function globalSearchHandler(q){
  if(!q.trim()) return;
  const empMatch = allUsers.find(u=>
    (u.firstName+' '+u.lastName).toLowerCase().includes(q.toLowerCase()) ||
    String(u.empId||'').toLowerCase().includes(q.toLowerCase())
  );
  if(empMatch){
    navTo('users', document.querySelector('[data-section=users]'));
    setTimeout(()=>{
      document.getElementById('userSearch').value = q;
      filterUsers(q);
    }, 100);
  }
}

/* ═══════════════════════════════════════════
   POPULATE DROPDOWNS
═══════════════════════════════════════════ */
function populateDeptDropdowns(){
  const selects = ['deptFilter','cdNewDept','attDeptSel','annDept'];
  selects.forEach(id=>{
    const el = document.getElementById(id);
    if(!el) return;
    const hasAll = el.querySelector('option[value=""]') || el.querySelector('option[value="ALL"]');
    DEPARTMENTS.forEach(d=>{
      const o = document.createElement('option');
      o.value = d; o.textContent = d;
      el.appendChild(o);
    });
    if(id==='annDept'){
      const allOpt = document.createElement('option');
      allOpt.value='ALL'; allOpt.textContent='All Departments';
      el.insertBefore(allOpt, el.firstChild);
    }
  });
}

/* ═══════════════════════════════════════════
   UTILS
═══════════════════════════════════════════ */
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtDate(s){ if(!s) return '—'; try { return new Date(s).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}); } catch(e){ return s; } }
function fmtTs(s){ if(!s) return '—'; try { return new Date(s).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}); } catch(e){ return s; } }
function fmtMins(m){ const h=Math.floor(m/60), min=m%60; return h>0?`${h}h ${min}m`:`${min}m`; }
function togglePw(id, btn){ const el=document.getElementById(id); el.type=el.type==='password'?'text':'password'; }

/* ═══════════════════════════════════════════
   INIT PREFERENCES FROM STORAGE
═══════════════════════════════════════════ */
(function(){
  const theme = localStorage.getItem('gh_admin_theme')||'dark';
  document.documentElement.setAttribute('data-theme', theme);
  document.querySelectorAll(`[data-theme="${theme}"]`).forEach(r=>r.classList.add('active'));
  const anim = localStorage.getItem('gh_anim');
  if(anim==='0'){
    document.documentElement.setAttribute('data-animations','false');
    const t = document.getElementById('animToggle');
    if(t) t.checked = false;
  }

  // Set default analytics dates
  const today = new Date().toISOString().split('T')[0];
  const w = new Date(); w.setDate(w.getDate()-6);
  const weekStart = w.toISOString().split('T')[0];
  const as = document.getElementById('analyticsStart');
  const ae = document.getElementById('analyticsEnd');
  if(as) as.value = weekStart;
  if(ae) ae.value = today;
})();
