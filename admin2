/* ═══════════════════════════════════════════
   CHARTS
═══════════════════════════════════════════ */
function renderCharts(tasks){
  tasks = tasks || allTasks;
  const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
  const gridC = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.08)';
  const tickC = isDark ? '#5a74a0' : '#3a5080';

  // Dept chart
  const deptMins = {};
  DEPARTMENTS.forEach(d=>deptMins[d]=0);
  tasks.forEach(t=>{if(t.dept && deptMins[t.dept]!==undefined) deptMins[t.dept]+=Number(t.durationMinutes||0);});
  const depts = Object.entries(deptMins).filter(([,m])=>m>0);
  if(deptChart) deptChart.destroy();
  const deptCtx = document.getElementById('deptChart');
  if(deptCtx && depts.length>0){
    deptChart = new Chart(deptCtx,{
      type:'doughnut',
      data:{
        labels:depts.map(([d])=>d),
        datasets:[{data:depts.map(([,m])=>m),backgroundColor:['#4d8af0','#a855f7','#10b981','#f43f5e','#ffd166','#00d4ff','#fb923c','#60a5fa','#34d399','#f87171','#c084fc'],borderWidth:2,borderColor:'transparent'}]
      },
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:tickC,font:{family:"'Exo 2',sans-serif",size:10},padding:8}}},cutout:'65%'}
    });
  }

  // Trend chart (7 days)
  const days7 = [];
  for(let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);days7.push(d.toISOString().split('T')[0]);}
  const dayMins = days7.map(d=>tasks.filter(t=>t.date===d).reduce((s,t)=>s+Number(t.durationMinutes||0),0)/60);
  if(barChart) barChart.destroy();
  const trendCtx = document.getElementById('trendChart');
  if(trendCtx){
    barChart = new Chart(trendCtx,{
      type:'line',
      data:{
        labels:days7.map(d=>new Date(d+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})),
        datasets:[{data:dayMins,fill:true,backgroundColor:'rgba(77,138,240,0.1)',borderColor:'var(--p)',borderWidth:2.5,tension:0.4,pointRadius:4,pointBackgroundColor:'var(--p)'}]
      },
      options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false}},
        scales:{
          y:{grid:{color:gridC},ticks:{callback:v=>v+'h',color:tickC},beginAtZero:true},
          x:{grid:{display:false},ticks:{color:tickC}}
        }
      }
    });
  }
}

