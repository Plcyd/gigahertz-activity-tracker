  const csv = ['Task,Employee,Date,Start,End,Duration (min),Remarks']
    .concat(tasks.map(t=>`"${t.taskName||''}","${t.empId||''}","${t.date||''}","${t.startTime||''}","${t.endTime||''}","${t.durationMinutes||''}","${(t.remarks||'').replace(/"/g,'""')}"`))
    .join('\n');
