    transparent 30%,
    rgba(255,255,255,0.04) 45%,
    rgba(255,255,255,0.08) 50%,
    rgba(255,255,255,0.04) 55%,
    transparent 70%
  );
  transform:translateX(-100%) rotate(0deg);
  transition:transform .6s ease;
  pointer-events:none;
}
.aero-shine:hover::after{transform:translateX(50%) rotate(0deg);}
[data-animations="false"] .aero-shine::after{display:none;}

