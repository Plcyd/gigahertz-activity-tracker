function setDefaultPayDates(){
  const d = new Date();
  const start = new Date(d.getFullYear(), d.getMonth(), 1).toISOString().split('T')[0];
  const end = d.toISOString().split('T')[0];
  document.getElementById('payStart').value = start;
  document.getElementById('payEnd').value = end;
}

async function loadPayroll(){
  const s = document.getElementById('payStart').value;
  const e = document.getElementById('payEnd').value;
  if(!s||!e){ toast('Set date range','info'); return; }
  const body = document.getElementById('payrollBody');
  body.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--tx3);">Loading...</td></tr>';
  try {
    const res = await gasPost({action:'getPayrollSummary',startDate:s,endDate:e});
    if(res.success && res.payroll) {
      payrollData = res.payroll;
    } else {
      // local fallback
      const filtered = allTasks.filter(t=>(!s||t.date>=s)&&(!e||t.date<=e));
      const map = {};
      filtered.forEach(t=>{
        const id = t.empId||t.userId||'?';
        if(!map[id]) map[id]={empId:id,totalMinutes:0,taskCount:0};
        map[id].totalMinutes += Number(t.durationMinutes||0);
        map[id].taskCount++;
      });
      payrollData = Object.values(map).map(r=>({...r,totalHours:(r.totalMinutes/60).toFixed(2)}));
    }
    renderPayroll();
  } catch(e2){ toast('Error loading payroll','error'); }
}

function renderPayroll(){
  const body = document.getElementById('payrollBody');
  if(!payrollData.length){body.innerHTML='<tr><td colspan="4" style="text-align:center;color:var(--tx3);">No data for selected range</td></tr>';return;}
  const max = Math.max(...payrollData.map(r=>Number(r.totalHours)));
  body.innerHTML = payrollData.sort((a,b)=>b.totalHours-a.totalHours).map(r=>{
    const h = Number(r.totalHours);
    const cls = h>=30?'pay-high':h>=15?'pay-med':'pay-low';
    return `
      <tr>
        <td style="font-weight:700;">${esc(r.empId||'—')}</td>
        <td>${r.taskCount||0}</td>
        <td class="${cls}">${h}h</td>
        <td><div class="progress-bar" style="margin:0;"><div class="progress-fill" style="width:${Math.round(h/max*100)}%"></div></div></td>
      </tr>
    `;
  }).join('');
}

function exportPayrollCSV(){
  if(!payrollData.length){ toast('Generate payroll first','info'); return; }
  const csv = ['Employee ID,Task Count,Total Hours']
    .concat(payrollData.map(r=>`${r.empId},${r.taskCount},${r.totalHours}`)).join('\n');
  downloadCSV(csv, 'payroll_export.csv');
